# ============================================
# Requi Health Backend - Environment Variables
# ============================================

# Application
APP_NAME=Requi Health API
APP_ENV=development
DEBUG=true

# CORS (pick one approach on the server)
# Allow any frontend origin (staging / multiple UIs — less secure for production):
CORS_ALLOW_ALL=true
# Or restrict to specific origins (comma-separated, no trailing slash):
# CORS_ORIGINS=http://52.62.222.6,https://app.example.com
# Or shorthand: CORS_ORIGINS=*
SECRET_KEY=your-super-secret-key-change-in-production
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# ─── DATABASE (only section to change for hosting) ───
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
# Or one line only (uncomment; overrides DB_* above):
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# Docker Compose: DB_HOST=postgres
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30
# ─── end DATABASE ───

# ─── REDIS & CELERY (background jobs; API warns at startup if unreachable) ───
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=50
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_WORKER_CONCURRENCY=4
# ─── end REDIS & CELERY ───

# Authentication
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI GPT-5.5 (Primary AI Model for all agents)
OPENAI_API_KEY=sk-openai-api-key-here
OPENAI_MODEL=gpt-5.5
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.1

# OpenAI Responses API (Intelligence — stored prompt + vector store)
OPENAI_PROMPT_ID=
OPENAI_PROMPT_VERSION=40
OPENAI_RESPONSES_MODEL=gpt-5
OPENAI_VECTOR_STORE_ID=

# OpenAI Realtime (live voice — Requi Sonia Assistant, Marin)
OPENAI_VOICE_PROMPT_ID=
OPENAI_VOICE_PROMPT_VERSION=7
# Must match the model on your Audio prompt template (Requi Sonia uses gpt-realtime-1.5).
OPENAI_REALTIME_MODEL=gpt-realtime-1.5
OPENAI_REALTIME_VOICE=marin

# Intelligence testing — simulated chat stream (no OpenAI). Use for UI/QA only.
MOCK_CHAT_STREAM=false
MOCK_CHAT_STREAM_DELAY_MS=50

# OpenAI Embeddings
EMBEDDING_MODEL=text-embedding-3-small

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_webhook_secret_here

# Stripe Checkout redirect URLs (no trailing slash)
FRONTEND_URL=http://localhost:5173

# Stripe Price IDs (v2.1 — must match app/core/config.py)
STRIPE_PRICE_STANDARD=price_standard_plan_id
STRIPE_PRICE_PRO=price_pro_plan_id
STRIPE_PRICE_ENTERPRISE=price_enterprise_plan_id

# Plan Configuration (cents) — v2.1
STANDARD_PLAN_PRICE=50000
STANDARD_PLAN_MIN_SEATS=1
STANDARD_PLAN_MAX_SEATS=1

PRO_PLAN_PRICE=150000
PRO_PLAN_MIN_SEATS=1
PRO_PLAN_MAX_SEATS=50

ENTERPRISE_PLAN_PRICE=350000
ENTERPRISE_PLAN_MIN_SEATS=5
ENTERPRISE_PLAN_MAX_SEATS=1000

# Knowledge Pipeline
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_SOURCES_PER_QUERY=5
MIN_CONFIDENCE_THRESHOLD=0.7
GAP_DETECTION_THRESHOLD=0.5

# Daily Update Job
DAILY_UPDATE_HOUR=2
DAILY_UPDATE_MINUTE=0
KNOWLEDGE_STALE_DAYS=30

# Document Storage
DOCUMENT_STORAGE_TYPE=local
S3_BUCKET_NAME=requi-documents
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Document ingestion (RAG chunks / embeddings)
# false (default) = index in the API process (no Celery worker; avoids stuck "Indexing…" when the queue is never consumed).
# true = queue Celery `ingest_document_task` (set when a worker is running, e.g. `worker` in docker-compose).
DOCUMENT_INGEST_USE_ASYNC_WORKER=false
# Deprecated: DOCUMENT_INGEST_SYNC=true means inline; false means Celery. Prefer DOCUMENT_INGEST_USE_ASYNC_WORKER above.

# SMTP (welcome email, trial reminders — Gmail: smtp.gmail.com:587 + App Password)
# Quote SMTP_PASSWORD if it contains spaces (Google App Password).
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD="your-app-password-here"
SMTP_FROM_EMAIL=
SMTP_SENDER_NAME=Requi Health

# Trial reminder (Celery Beat — 9:00 AM US Pacific, email when 2 calendar days left)
TRIAL_REMINDER_EMAIL_ENABLED=true
TRIAL_REMINDER_DAYS_BEFORE_END=2
TRIAL_REMINDER_CRON_HOUR=9
TRIAL_REMINDER_CRON_MINUTE=0
TRIAL_REMINDER_TIMEZONE=America/Los_Angeles

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
